{
  "manifest_version": 3,
  "name": "OpenCode API Connector",
  "version": "0.4.0",
  "description": "统一连接器，支持 OpenCode Go、xAI Grok 等多种账号池的自动录入。",
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "cookies"
  ],
  "host_permissions": [
    "https://opencode.ai/*",
    "https://auth.opencode.ai/*",
    "https://*.x.ai/*",
    "https://x.ai/*",
    "https://*.grok.com/*",
    "https://grok.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OpenCode API Connector"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://auth.opencode.ai/*"
      ],
      "js": [
        "google-login.js",
        "page-overlay.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://auth.x.ai/*"
      ],
      "js": [
        "xai-auto-authorize.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://opencode.ai/*"
      ],
      "js": [
        "page-overlay.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
