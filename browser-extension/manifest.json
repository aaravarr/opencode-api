{
  "manifest_version": 3,
  "name": "OpenCode Go Connector",
  "version": "0.2.1",
  "description": "完成 OpenCode Google 登录并连接到 OpenCode Go Router。",
  "permissions": ["storage", "tabs", "windows", "cookies"],
  "host_permissions": [
    "https://opencode.ai/*",
    "https://auth.opencode.ai/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OpenCode Go Connector"
  },
  "options_page": "options.html",
 "content_scripts": [
   {
     "matches": ["https://auth.opencode.ai/*"],
     "js": ["google-login.js"],
     "run_at": "document_idle"
   },
   {
     "matches": ["https://opencode.ai/*"],
     "js": ["page-overlay.js"],
     "run_at": "document_idle"
   }
 ]
}
